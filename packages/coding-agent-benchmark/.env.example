########################################################
### Vercel Environment Variables
########################################################
VERCEL_TOKEN=<your-vercel-access-token>
VERCEL_TEAM_ID=<your-vercel-team-id>
VERCEL_PROJECT_ID=<your-vercel-project-id>

# populated after running the create-snapshot script.
# by default, snapshots expire after 30 days.
CLAUDE_CODE_BASE_SNAPSHOT_ID=""
CLAUDE_CODE_SUPERPOWERS_SNAPSHOT_ID=""
CLAUDE_CODE_SUPERPOWERS_FORK_SNAPSHOT_ID=""
CLAUDE_CODE_CLAUDE_MD_SNAPSHOT_ID=""

########################################################
### Azure Foundry Environment Variables
########################################################
ANTHROPIC_FOUNDRY_RESOURCE=<your-anthropic-foundry-resource>
ANTHROPIC_FOUNDRY_API_KEY=<your-anthropic-foundry-api-key>
ANTHROPIC_FOUNDRY_API_VERSION=<your-anthropic-foundry-api-version>

########################################################
### Braintrust
########################################################
BRAINTRUST_ENDPOINT="https://gateway.braintrust.dev"
BRAINTRUST_API_KEY=<your-braintrust-api-key>

########################################################
### Judge models
########################################################
CODE_JUDGE_MODEL="gpt-5.3-codex"
LIGHT_JUDGE_MODEL="gpt-5.4-mini"

HUMAN_AGENT_MODEL="us.anthropic.claude-sonnet-4-6"