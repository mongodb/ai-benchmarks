# Note: The quiz questions are stored in staging
MONGODB_QUIZ_QUESTIONS_CONNECTION_URI="mongodb+srv://<user>:<pass>@docs-chatbot-staging.ngvo1.mongodb.net/?retryWrites=true&w=majority"
MONGODB_QUIZ_QUESTIONS_DATABASE_NAME="datasets"
MONGODB_QUIZ_QUESTIONS_COLLECTION_NAME="quiz_questions"
MONGODB_TEXT_TO_DRIVER_CONNECTION_URI="<CONNECTION URI>"
BRAINTRUST_ENDPOINT="https://gateway.braintrust.dev"
# NOTE: MUST be separate from the BRAINTRUST_API_KEY, 
# because the gateway API key is injected into an uncontrolled environment
# with the model. We do not want to:
# 1. Give model unrestricted access to Braintrust!
# 2. Potentially have the key leak in a published transcript!
# To install!
# Create a service token that can ONLY access the API Gateway,
# not any Braintrust projects or other resources.
# See: https://www.braintrust.dev/docs/deploy/gateway
BRAINTRUST_GATEWAY_API_KEY="<read above comment!! -- some gateway api key -- read above comment!!>"
BRAINTRUST_API_KEY="<some api key>"
BRAINTRUST_TEXT_TO_DRIVER_PROJECT_NAME="<some project>"
OPENAI_API_VERSION="2024-06-01"
OPENAI_ENDPOINT="https://<resource_name>.openai.azure.com/"
OPENAI_API_KEY="<api_key>"
MONGODB_TEXT_TO_DRIVER_CONNECTION_URI="<CONNECTION URI>"
VERCEL_OIDC_TOKEN="<vercel oidc token>"